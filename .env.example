# ╔══════════════════════════════════════════════════════════════╗
# ║          Doc-Review PoC — Environment Configuration         ║
# ║  Copy this file to .env and fill in your Azure values.      ║
# ║  Find these in Azure AI Foundry → your project → Overview   ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Azure Subscription / Resource Group ───────────────────────
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=my-resource-group

# ── Azure AI Foundry Project ──────────────────────────────────
AZURE_AI_PROJECT_NAME=my-ai-project
AZURE_AI_PROJECT_ENDPOINT=https://my-project.services.ai.azure.com

# ── Azure OpenAI ──────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://my-openai.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Azure AI Search ───────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://my-search.search.windows.net
AZURE_SEARCH_INDEX_NAME=doc-review-index

# ── Azure Blob Storage ────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=mystorageaccount
AZURE_STORAGE_CONTAINER_NAME=documents

# ── Azure Content Understanding ───────────────────────────────
# Create your analyzer via: python scripts/create_cu_analyzer.py
AZURE_CU_ENDPOINT=https://my-project.services.ai.azure.com
AZURE_CU_ANALYZER_ID=doc-review-analyzer

# ── Optional: API Key Fallback ────────────────────────────────
# Leave these BLANK to use DefaultAzureCredential (recommended).
# Only set if your environment does not support az login / managed identity.
AZURE_OPENAI_API_KEY=
AZURE_SEARCH_API_KEY=
AZURE_CU_API_KEY=
AZURE_STORAGE_CONNECTION_STRING=
